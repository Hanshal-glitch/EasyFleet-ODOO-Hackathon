{
  "name": "transport-ops-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@transport-ops/backend\" \"npm run dev --workspace=@transport-ops/frontend\"",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=@transport-ops/backend",
    "build:frontend": "npm run build --workspace=@transport-ops/frontend",
    "db:generate": "npm run db:generate --workspace=@transport-ops/backend",
    "db:migrate": "npm run db:migrate --workspace=@transport-ops/backend",
    "db:seed": "npm run db:seed --workspace=@transport-ops/backend",
    "db:studio": "npm run db:studio --workspace=@transport-ops/backend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:prod:up": "docker-compose -f docker-compose.yml up -d",
    "docker:prod:down": "docker-compose -f docker-compose.yml down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}